@mcpUrl = http://localhost:5000/mcp
@sessionId = replace-me

### Initialize
POST {{mcpUrl}}
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize"
}

### Tools List
POST {{mcpUrl}}
Content-Type: application/json
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/list"
}

### Catalog List
POST {{mcpUrl}}
Content-Type: application/json
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "catalog/list"
}

### Catalog Search
POST {{mcpUrl}}
Content-Type: application/json
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "catalog/search",
  "params": {
    "query": "book",
    "tags": ["query"],
    "limit": 5
  }
}

### Call Hello
POST {{mcpUrl}}
Content-Type: application/json
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 5,
  "method": "tools/call",
  "params": {
    "name": "get_hello",
    "arguments": {
      "name": "Claude"
    }
  }
}

### Call Book By Title
POST {{mcpUrl}}
Content-Type: application/json
Mcp-Session-Id: {{sessionId}}

{
  "jsonrpc": "2.0",
  "id": 6,
  "method": "tools/call",
  "params": {
    "name": "get_bookByTitle",
    "arguments": {
      "title": "GraphQL"
    }
  }
}
